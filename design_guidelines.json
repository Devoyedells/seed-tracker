  "instructions_to_main_agent": [
    "Install 'lucide-react' for icons if not installed.",
    "Install 'recharts' for analytics charts.",
    "Install 'react-leaflet' and 'leaflet' for the interactive map.",
    "Install 'framer-motion' for smooth transitions.",
    "Update 'tailwind.config.js' to include the custom colors (#1EB53A, #0072C6).",
    "Ensure the Landing Page uses the 'hero_background' image with a dark overlay (bg-black/40) to make text readable.",
    "The Dashboard must be dense and data-heavy. Use the 'High Density Grid' strategy.",
    "Use 'Manrope' font for all headings to give a modern technical feel.",
    "Ensure all interactive elements (buttons, inputs) have 'data-testid' attributes.",
    "Use the 'Sierra Leone Green' for primary buttons and 'Sierra Leone Blue' for secondary/info elements.",
    "Do NOT use gradients for backgrounds. Use solid colors or subtle patterns/images.",
    "For the 'Map' component, center it on Sierra Leone (8.4606, -11.7799) with a default zoom of 8."
  ],
  "UNIVERSAL_GUIDELINES": {
    "principles": [
      "Fusion over Imitation: Mix agricultural warmth with government precision.",
      "Content is King: Data must be legible. Use tabular numbers (font-variant-numeric: tabular-nums) for data.",
      "Negative Space: Don't clutter the dashboard. Group related metrics.",
      "Accessibility: Ensure contrast ratios (Green on White) are WCAG AA compliant."
    ],
    "anti_patterns": [
      "Do not use purple/teal/pink. Stick to the Green/Blue/White/Earth palette.",
      "No centered layouts for dashboards.",
      "No 'Inter' for headings. Use 'Manrope'."
    ]
  }
}