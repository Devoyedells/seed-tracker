{
  "brand": {
    "name": "Sierra Leone Seed Tracker",
    "identity": {
      "tone": "Official, Trustworthy, Organic, Growth-oriented",
      "keywords": ["Transparency", "Agriculture", "Growth", "Quality", "Sierra Leone"],
      "theme_mode": "light"
    },
    "colors": {
      "primary": {
        "name": "Sierra Leone Green",
        "hex": "#1EB53A",
        "hsl": "131 71% 41%",
        "description": "Main brand color. Used for primary actions, success states, and key visual elements."
      },
      "secondary": {
        "name": "Sierra Leone Blue",
        "hex": "#0072C6",
        "hsl": "205 100% 39%",
        "description": "Secondary brand color. Used for official government badges, info states, and trust indicators."
      },
      "accent": {
        "name": "Harvest Gold",
        "hex": "#DAA520",
        "hsl": "43 74% 49%",
        "description": "Highlight color for calls-to-action that need to stand out against green/blue."
      },
      "neutral": {
        "background": "#F9FAFB",
        "surface": "#FFFFFF",
        "text_primary": "#111827",
        "text_secondary": "#4B5563",
        "border": "#E5E7EB"
      }
    },
    "typography": {
      "headings": {
        "font_family": "Manrope, sans-serif",
        "weights": ["600", "700", "800"],
        "description": "Modern, geometric but friendly. Good for UI and data display."
      },
      "body": {
        "font_family": "Inter, sans-serif",
        "weights": ["400", "500"],
        "description": "Clean, highly legible for dense data."
      }
    }
  },
  "layout_strategy": {
    "spacing": {
      "base_unit": 4,
      "scale": {
        "container_padding": "p-4 md:p-8 lg:p-12",
        "section_gap": "gap-8 md:gap-16",
        "component_gap": "gap-4"
      }
    },
    "grid_system": {
      "marketing": "grid-cols-1 md:grid-cols-12 gap-6",
      "dashboard": "grid-cols-1 md:grid-cols-4 lg:grid-cols-12 gap-4"
    },
    "containers": {
      "max_width": "max-w-7xl",
      "center": "mx-auto"
    }
  },
  "visual_enhancers": {
    "radius": {
      "default": "rounded-lg",
      "card": "rounded-xl",
      "button": "rounded-md"
    },
    "shadows": {
      "card": "shadow-sm hover:shadow-md transition-shadow",
      "dropdown": "shadow-lg",
      "modal": "shadow-2xl"
    },
    "glassmorphism": {
      "header": "bg-white/80 backdrop-blur-md border-b border-gray-100",
      "overlay": "bg-black/20 backdrop-blur-sm"
    },
    "animations": {
      "hover": "transition-all duration-200 ease-out",
      "enter": "animate-in fade-in zoom-in-95 duration-300"
    }
  },
  "component_styles": {
    "buttons": {
      "primary": "bg-[#1EB53A] hover:bg-[#168a2c] text-white shadow-md font-semibold",
      "secondary": "bg-white border border-[#1EB53A] text-[#1EB53A] hover:bg-green-50",
      "outline": "border border-gray-200 bg-transparent hover:bg-gray-50 text-gray-700",
      "ghost": "hover:bg-gray-100 text-gray-700"
    },
    "cards": {
      "base": "bg-white border border-gray-100 shadow-sm rounded-xl overflow-hidden",
      "interactive": "hover:border-[#1EB53A]/50 hover:shadow-md cursor-pointer transition-all"
    },
    "inputs": {
      "base": "bg-white border-gray-200 focus:border-[#1EB53A] focus:ring-[#1EB53A]/20 rounded-md"
    },
    "badges": {
      "success": "bg-green-100 text-green-800 border-green-200",
      "warning": "bg-yellow-100 text-yellow-800 border-yellow-200",
      "info": "bg-blue-100 text-blue-800 border-blue-200",
      "neutral": "bg-gray-100 text-gray-800 border-gray-200"
    }
  },
